{
  "name": "memory-milvus",
  "version": "0.1.0",
  "description": "Milvus-backed memory plugin for OpenClaw with hybrid search (vector + BM25)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "memory",
    "milvus",
    "vector-search",
    "hybrid-search"
  ],
  "author": "Chun",
  "license": "MIT",
  "dependencies": {
    "@sinclair/typebox": "^0.33.0",
    "@zilliz/milvus2-sdk-node": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0"
  },
  "peerDependencies": {
    "openclaw": ">=2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
